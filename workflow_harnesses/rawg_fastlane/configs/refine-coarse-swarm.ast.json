{
  "schema_version": "kituniverse.workflow-ast.v1",
  "workflow_id": "rawg-refine-coarse-swarm-v1",
  "controls": {
    "source_root": "/Users/crimsonwheeler/Documents/GitHub/NexusRealtime-Ideas/games/rawg/chunks",
    "workspace": "runs/rawg-fastlane/benchmark-coarse-20k",
    "base_url": "http://10.0.0.137:1234/v1",
    "task_concurrency": 64,
    "model_prediction_limits": {"lfm2.5-1.2b-instruct": 8, "lfm2.5-350m": 64},
    "max_context_tokens": 2000,
    "timeout_seconds": 45,
