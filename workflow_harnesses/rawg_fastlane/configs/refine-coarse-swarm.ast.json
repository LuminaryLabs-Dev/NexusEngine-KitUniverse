  "nodes": [
    {"id": "scan", "op": "rawg.scan-group", "enabled": false, "config": {"fingerprint_profile": "coarse"}},
    {"id": "swarm", "op": "lfm.swarm-ideas", "enabled": false, "config": {"model": "lfm2.5-350m"}},
    {"id": "refine", "op": "lfm.refine-swarm", "config": {"model": "lfm2.5-1.2b-instruct", "temperature": 0.7, "max_tokens": 96, "max_results": 256}},
    {"id": "review", "op": "codex.review-recall", "goal": "Decide whether the coarse fingerprint plus 64-lane 350M swarm and 1.2B batched refinement preserves enough evidence-backed novelty for a six-hour RAWG pass.", "permissions": {"repo_edits": false, "shell_mutation": false}, "loop": {"max_passes": 2, "stop_score": 0.9}},
    {"id": "report", "op": "workflow.report"}
  ],
  "edges": [{"from": "scan", "to": "swarm"}, {"from": "swarm", "to": "refine"}, {"from": "refine", "to": "review"}, {"from": "review", "to": "report"}]
}
