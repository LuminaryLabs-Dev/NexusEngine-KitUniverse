{
  "schema_version": "kituniverse.workflow-ast.v1",
  "workflow_id": "rawg-merge-swarm-v1",
  "controls": {
    "source_root": "/Users/crimsonwheeler/Documents/GitHub/NexusRealtime-Ideas/games/rawg/chunks",
    "workspace": "runs/rawg-fastlane/benchmark-stratified-3-controlled-20k",
    "base_url": "http://10.0.0.137:1234/v1",
    "task_concurrency": 64,
    "model_prediction_limits": {"lfm2.5-1.2b-instruct": 8, "lfm2.5-350m": 64},
    "max_context_tokens": 2000,
    "timeout_seconds": 45,
    "shard_max_bytes": 90000000
  },
  "nodes": [
    {"id": "scan", "op": "rawg.scan-group", "enabled": false, "config": {"fingerprint_profile": "stratified"}},
    {"id": "swarm", "op": "lfm.swarm-ideas", "enabled": false, "config": {"model": "lfm2.5-350m"}},
    {"id": "merge", "op": "swarm.merge-clusters", "config": {"min_support": 2, "singleton_recall": 32}},
    {"id": "review", "op": "codex.review-recall", "enabled": false, "goal": "Validate swarm cluster support milestones.", "permissions": {"repo_edits": false, "shell_mutation": false}, "loop": {"max_passes": 2, "stop_score": 0.9}},
    {"id": "report", "op": "workflow.report"}
  ],
  "edges": [{"from": "scan", "to": "swarm"}, {"from": "swarm", "to": "merge"}, {"from": "merge", "to": "review"}, {"from": "review", "to": "report"}]
}
