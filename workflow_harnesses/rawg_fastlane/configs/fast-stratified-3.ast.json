{
  "schema_version": "kituniverse.workflow-ast.v1",
  "workflow_id": "rawg-fast-stratified-3-v1",
  "controls": {
    "source_root": "/Users/crimsonwheeler/Documents/GitHub/NexusRealtime-Ideas/games/rawg/chunks",
    "workspace": "runs/rawg-881k/fast-stratified-3",
    "base_url": "http://10.0.0.137:1234/v1",
    "task_concurrency": 64,
    "model_prediction_limits": {"lfm2.5-1.2b-instruct": 8, "lfm2.5-350m": 64},
    "max_context_tokens": 2000,
    "timeout_seconds": 45,
    "shard_max_bytes": 90000000
  },
  "nodes": [
    {"id": "scan", "op": "rawg.scan-group", "config": {"fingerprint_profile": "stratified", "max_representatives_per_group": 3, "max_records": 0}},
    {"id": "swarm", "op": "lfm.swarm-ideas", "enabled": false, "config": {"model": "lfm2.5-350m", "temperature": 1.2, "beam_width": 4, "context_tokens": 512}},
    {"id": "refine", "op": "lfm.refine-swarm", "enabled": false, "config": {"model": "lfm2.5-1.2b-instruct", "temperature": 0.7}},
    {"id": "review", "op": "codex.review-recall", "enabled": false, "goal": "Validate stratified grouping quality and speed.", "permissions": {"repo_edits": false, "shell_mutation": false}, "loop": {"max_passes": 2, "stop_score": 0.9}},
    {"id": "report", "op": "workflow.report"}
  ],
  "edges": [{"from": "scan", "to": "swarm"}, {"from": "swarm", "to": "refine"}, {"from": "refine", "to": "review"}, {"from": "review", "to": "report"}]
}
