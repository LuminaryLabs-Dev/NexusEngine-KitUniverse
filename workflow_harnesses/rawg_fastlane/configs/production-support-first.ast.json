{
  "schema_version": "kituniverse.workflow-ast.v1",
  "workflow_id": "rawg-production-support-first-v1",
  "controls": {
    "source_root": "/Users/crimsonwheeler/Documents/GitHub/NexusRealtime-Ideas/games/rawg/chunks",
    "workspace": "runs/rawg-881k/fast-support-first-production",
    "base_url": "http://10.0.0.137:1234/v1",
    "task_concurrency": 64,
    "model_prediction_limits": {"lfm2.5-1.2b-instruct": 8, "lfm2.5-350m": 64},
    "max_context_tokens": 2000,
    "timeout_seconds": 45,
    "shard_max_bytes": 90000000,
    "min_free_gib": 10.0,
    "promotion_enabled": false
  },
  "nodes": [
    {"id": "scan", "op": "rawg.scan-group", "config": {"fingerprint_profile": "stratified", "max_representatives_per_group": 12, "max_records": 0}},
    {
      "id": "pipeline",
      "op": "workflow.support-first-pipeline",
      "config": {
        "swarm_batch": 2048,
        "refine_batch": 256,
        "max_iterations": 100,
        "swarm": {"model": "lfm2.5-350m", "temperature": 1.2, "beam_width": 4, "context_tokens": 512, "max_tokens": 64, "allow_reconfigure": true},
        "merge": {"min_support": 2, "singleton_recall": 32},
        "refine": {"model": "lfm2.5-1.2b-instruct", "temperature": 0.7, "max_tokens": 96, "min_support": 2, "include_singleton_recall": true, "singleton_quota": 16, "full_corpus_cap": 10000, "novelty_metrics": false}
      }
    },
    {
      "id": "review",
      "op": "codex.review-recall",
      "goal": "Review the complete 881,069-record support-first shadow pass for atomic evidence quality, novelty, rare recall, call efficiency, and kit-cluster readiness. Promotion remains disabled.",
      "recall_paths": ["goal.md", "memory.md", "workflow_harnesses/rawg_fastlane/README.md", "runs/workflow-harnesses/rawg-matrix-optimizer/20260712-023830-383/report.json"],
      "permissions": {"repo_edits": false, "shell_mutation": false},
      "loop": {"max_passes": 2, "stop_score": 0.9}
    },
    {"id": "report", "op": "workflow.report"}
  ],
  "edges": [{"from": "scan", "to": "pipeline"}, {"from": "pipeline", "to": "review"}, {"from": "review", "to": "report"}]
}
