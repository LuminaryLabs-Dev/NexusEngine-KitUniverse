{
  "schema_version": "kituniverse.workflow-ast.v1",
  "workflow_id": "rawg-benchmark-support-first-clean-v1",
  "controls": {
    "source_root": "/Users/crimsonwheeler/Documents/GitHub/NexusRealtime-Ideas/games/rawg/chunks",
    "workspace": "runs/rawg-fastlane/benchmark-support-first-clean-20k",
    "base_url": "http://10.0.0.137:1234/v1",
    "task_concurrency": 64,
    "model_prediction_limits": {"lfm2.5-1.2b-instruct": 8, "lfm2.5-350m": 64},
    "max_context_tokens": 2000,
    "timeout_seconds": 45,
    "shard_max_bytes": 90000000
  },
  "nodes": [
    {"id": "scan", "op": "rawg.scan-group", "config": {"fingerprint_profile": "stratified", "max_representatives_per_group": 3, "max_records": 20000}},
    {"id": "swarm", "op": "lfm.swarm-ideas", "config": {"model": "lfm2.5-350m", "temperature": 1.2, "beam_width": 4, "context_tokens": 512, "max_tokens": 64, "max_representatives": 0, "allow_reconfigure": true}},
    {"id": "merge", "op": "swarm.merge-clusters", "config": {"min_support": 2, "singleton_recall": 32}},
    {"id": "refine", "op": "lfm.refine-clusters", "config": {"model": "lfm2.5-1.2b-instruct", "temperature": 0.7, "max_tokens": 96, "min_support": 2, "include_singleton_recall": true, "singleton_quota": 16, "max_clusters": 96, "full_corpus_cap": 10000}},
    {
      "id": "review",
      "op": "codex.review-recall",
      "goal": "Compare the clean support-first action-object pipeline against the matrix reference for novelty, quality, call yield, rare evidence recall, and six-hour feasibility.",
      "recall_paths": ["goal.md", "memory.md", "workflow_harnesses/rawg_fastlane/README.md", "runs/workflow-harnesses/rawg-matrix-optimizer/20260712-023830-383/report.json"],
      "permissions": {"repo_edits": false, "shell_mutation": false},
      "loop": {"max_passes": 2, "stop_score": 0.9}
    },
    {"id": "report", "op": "workflow.report"}
  ],
  "edges": [{"from": "scan", "to": "swarm"}, {"from": "swarm", "to": "merge"}, {"from": "merge", "to": "refine"}, {"from": "refine", "to": "review"}, {"from": "review", "to": "report"}]
}
