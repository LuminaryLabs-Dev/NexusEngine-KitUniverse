{
  "schema_version": "kituniverse.workflow-ast.v1",
  "workflow_id": "rawg-benchmark-pipelined-5k-v1",
  "controls": {
    "source_root": "/Users/crimsonwheeler/Documents/GitHub/NexusRealtime-Ideas/games/rawg/chunks",
    "workspace": "runs/rawg-fastlane/benchmark-pipelined-5k",
    "base_url": "http://10.0.0.137:1234/v1",
    "task_concurrency": 64,
    "model_prediction_limits": {"lfm2.5-1.2b-instruct": 8, "lfm2.5-350m": 64},
    "max_context_tokens": 2000,
    "timeout_seconds": 45,
    "shard_max_bytes": 90000000
  },
  "nodes": [
    {"id": "scan", "op": "rawg.scan-group", "config": {"fingerprint_profile": "stratified", "max_representatives_per_group": 3, "max_records": 5000}},
    {
      "id": "pipeline",
      "op": "workflow.support-first-pipeline",
      "config": {
        "swarm_batch": 128,
        "refine_batch": 48,
        "max_iterations": 20,
        "swarm": {"model": "lfm2.5-350m", "temperature": 1.2, "beam_width": 4, "context_tokens": 512, "max_tokens": 64, "allow_reconfigure": true},
        "merge": {"min_support": 2, "singleton_recall": 16},
        "refine": {"model": "lfm2.5-1.2b-instruct", "temperature": 0.7, "max_tokens": 96, "min_support": 2, "include_singleton_recall": true, "singleton_quota": 8, "full_corpus_cap": 10000, "novelty_metrics": false}
      }
    },
    {"id": "review", "op": "codex.review-recall", "enabled": false, "goal": "Measure actual concurrent swarm and support-refinement overlap.", "permissions": {"repo_edits": false, "shell_mutation": false}, "loop": {"max_passes": 2, "stop_score": 0.9}},
    {"id": "report", "op": "workflow.report"}
  ],
  "edges": [{"from": "scan", "to": "pipeline"}, {"from": "pipeline", "to": "review"}, {"from": "review", "to": "report"}]
}
