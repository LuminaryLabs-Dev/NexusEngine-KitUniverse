{
  "schema_version": "kituniverse.exhaustive-workflow-ast.v1",
  "workflow_id": "rawg-exhaustive-production-v1",
  "controls": {
    "source_root": "/Users/crimsonwheeler/Documents/GitHub/NexusRealtime-Ideas/games/rawg/chunks",
    "workspace": "runs/rawg-881k/exhaustive-production",
    "engine_root": "/Users/crimsonwheeler/Documents/GitHub/NexusEngine",
    "protokits_root": "/Users/crimsonwheeler/Documents/GitHub/NexusEngine-ProtoKits",
    "simulator_cli": "/Users/crimsonwheeler/Documents/GitHub/NexusSimulator/NexusSimulator-V1/src/cli.js",
    "base_url": "http://10.0.0.137:1234/v1",
    "task_concurrency": 64,
    "model_prediction_limits": {"lfm2.5-350m": 64, "lfm2.5-1.2b-instruct": 8},
    "max_context_tokens": 2000,
    "timeout_seconds": 45,
    "shard_max_bytes": 90000000,
    "min_free_gib": 10.0,
    "promotion_enabled": false
  },
  "nodes": [
    {"id": "map", "op": "rawg.map-evidence", "config": {"max_records": 0}},
    {"id": "extract", "op": "lfm.extract-interactions", "config": {"model": "lfm2.5-350m", "temperature": 1.2, "context_tokens": 512, "max_tokens": 160, "evidence_units_per_page": 12, "dispatch_batch": 2048, "retries": 1, "max_pages": 0}},
    {"id": "decompose", "op": "kit.expand-pointer-decomposition", "config": {}},
    {"id": "merge", "op": "master.merge-observations"},
    {"id": "refine", "op": "lfm.refine-master-kits", "config": {"model": "lfm2.5-1.2b-instruct", "temperature": 0.2, "context_tokens": 2000, "max_tokens": 320, "retries": 1, "max_master_kits": 0}},
    {"id": "review", "op": "codex.review-master-kits", "config": {"batch_size": 25, "max_batches": 0, "timeout_seconds": 900}},
    {"id": "enqueue", "op": "kit.enqueue-builds"},
    {"id": "build", "op": "kit.build-runtime-prove", "config": {"max_builds": 0, "timeout_seconds": 300}},
    {"id": "report", "op": "workflow.report"}
  ],
  "edges": [
    {"from": "map", "to": "extract"},
    {"from": "extract", "to": "decompose"},
    {"from": "decompose", "to": "merge"},
    {"from": "merge", "to": "refine"},
    {"from": "refine", "to": "review"},
    {"from": "review", "to": "enqueue"},
    {"from": "enqueue", "to": "build"},
    {"from": "build", "to": "report"}
  ]
}
